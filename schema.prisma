generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  groupMemberships    GroupMember[]
  paidExpenses        Expense[]      @relation("PaidByUser")
  expenseSplits       ExpenseSplit[]
  sentSettlements     Settlement[]   @relation("Payer")
  receivedSettlements Settlement[]   @relation("Payee")

  @@map("users")
}

model Group {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  members  GroupMember[]
  expenses Expense[]

  @@map("groups")
}

model GroupMember {
  id       String   @id @default(cuid())
  joinedAt DateTime @default(now())

  userId  String
  groupId String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@map("group_members")
}

model Expense {
  id          String    @id @default(cuid())
  title       String
  totalAmount Decimal   @db.Decimal(10, 2)
  splitType   SplitType
  // raw input stored for audits — actual resolved amounts live in ExpenseSplit
  splitInput  Json
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  paidById String
  groupId  String

  group  Group          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  paidBy User           @relation("PaidByUser", fields: [paidById], references: [id])
  splits ExpenseSplit[]

  @@map("expenses")
}

model ExpenseSplit {
  id             String   @id @default(cuid())
  resolvedAmount Decimal  @db.Decimal(10, 2) // always the final calculated amount
  isSettled      Boolean  @default(false)
  createdAt      DateTime @default(now())

  expenseId String
  userId    String

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([expenseId, userId])
  @@map("expense_splits")
}

model Settlement {
  id        String           @id @default(cuid())
  amount    Decimal          @db.Decimal(10, 2)
  status    SettlementStatus @default(PENDING)
  note      String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  payerId String
  payeeId String

  payer User @relation("Payer", fields: [payerId], references: [id])
  payee User @relation("Payee", fields: [payeeId], references: [id])

  @@map("settlements")
}

enum SplitType {
  EQUAL
  PERCENTAGE
  EXACT
}

enum SettlementStatus {
  PENDING
  CONFIRMED
}
