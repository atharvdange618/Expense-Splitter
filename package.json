{
  "name": "expense-splitter-api",
  "version": "1.0.0",
  "description": "NestJS-inspired expense splitter API with Express, Prisma, and PostgreSQL",
  "main": "src/server.ts",
  "scripts": {
    "dev": "dotenvx run -- tsx watch src/server.ts",
    "build": "tsc",
    "start": "dotenvx run -- node dist/server.js",
    "db:migrate": "dotenvx run -- prisma migrate dev",
    "db:generate": "dotenvx run -- prisma generate",
    "db:push": "dotenvx run -- prisma db push",
    "db:studio": "dotenvx run -- prisma studio",
    "db:migrate:deploy": "dotenvx run -- prisma migrate deploy"
  },
  "keywords": [
    "expense",
    "splitter",
    "api",
    "express",
    "prisma"
  ],
  "author": "Atharv Dange",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^6.18.0",
    "arktype": "^2.2.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "decimal.js": "^10.6.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "linkedom": "^0.18.12",
    "morgan": "^1.10.0",
    "uuid": "^13.0.0",
    "validator": "^13.15.26"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.31.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.11.16",
    "@types/uuid": "^11.0.0",
    "@types/validator": "^13.15.10",
    "prisma": "6.18.0",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  }
}
